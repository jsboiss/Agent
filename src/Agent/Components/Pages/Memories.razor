@page "/memories"
@using Agent.Memory
@inject IMemoryStore MemoryStore

<PageTitle>Memories</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <div>
            <MudText Typo="Typo.overline" Color="Color.Secondary">SQLite memory store</MudText>
            <MudText Typo="Typo.h4">Memories</MudText>
        </div>
        <MudTextField T="string"
                      @bind-Value="SearchText"
                      Placeholder="Search memories"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      TextChanged="SearchMemories" />
    </MudStack>

    <MudPaper Elevation="0" Outlined="true">
        <MudTable Items="MemoryRows" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Tier</MudTh>
                <MudTh>Segment</MudTh>
                <MudTh>Lifecycle</MudTh>
                <MudTh>Memory</MudTh>
                <MudTh>Score</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tier">
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.Tier</MudChip>
                </MudTd>
                <MudTd DataLabel="Segment">@context.Segment</MudTd>
                <MudTd DataLabel="Lifecycle">@context.Lifecycle</MudTd>
                <MudTd DataLabel="Memory">@context.Text</MudTd>
                <MudTd DataLabel="Score">@context.Score</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private IReadOnlyList<MemoryRow> MemoryRows { get; set; } = [];

    private string SearchText { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadMemories(string.Empty);
    }

    private async Task SearchMemories(string value)
    {
        SearchText = value;
        await LoadMemories(SearchText);
    }

    private async Task LoadMemories(string query)
    {
        var memories = await MemoryStore.Search(
            new MemorySearchRequest(
                query,
                50,
                new HashSet<MemoryLifecycle> { MemoryLifecycle.Active },
                new Dictionary<string, string>()),
            CancellationToken.None);

        MemoryRows = memories
            .Select(x => new MemoryRow(
                x.Tier.ToString(),
                x.Segment.ToString(),
                x.Lifecycle.ToString(),
                x.Text,
                $"{x.Importance:0.##}/{x.Confidence:0.##}"))
            .ToArray();
    }

    private sealed record MemoryRow(string Tier, string Segment, string Lifecycle, string Text, string Score);
}
