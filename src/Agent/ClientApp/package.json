{
  "name": "mainagent-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "generate-api": "orval --config orval.config.ts",
    "typecheck": "tsc --noEmit",
