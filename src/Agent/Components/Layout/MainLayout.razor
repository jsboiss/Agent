@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="left-rail" aria-label="Main navigation">
        <a class="brand-mark" href="/" title="Agent">A</a>
        <nav class="rail-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="rail-link" title="Chat">
                <span aria-hidden="true">C</span>
                <span>Chat</span>
            </NavLink>
            <NavLink href="/memories" class="rail-link" title="Memories">
                <span aria-hidden="true">M</span>
                <span>Memories</span>
            </NavLink>
            <NavLink href="/runs" class="rail-link" title="Runs">
                <span aria-hidden="true">R</span>
                <span>Runs</span>
            </NavLink>
            <NavLink href="/graph" class="rail-link" title="Graph">
                <span aria-hidden="true">G</span>
                <span>Graph</span>
            </NavLink>
            <NavLink href="/settings" class="rail-link" title="Settings">
                <span aria-hidden="true">S</span>
                <span>Settings</span>
            </NavLink>
        </nav>
    </aside>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
