@page "/settings"
@rendermode InteractiveServer
@using Agent.Conversations
@using Agent.Memory
@using Agent.Settings
@using Microsoft.Extensions.Options
@inject IAgentSettingsResolver SettingsResolver
@inject IOptions<SqliteMemoryOptions> MemoryOptions

<PageTitle>Settings</PageTitle>

<section class="workspace">
    <header class="workspace-header">
        <div>
            <p class="eyebrow">Read-only configuration</p>
            <h1>Settings</h1>
        </div>
    </header>

    <div class="settings-grid">
        <section class="panel">
            <h2>Provider</h2>
            <dl>
                <dt>Provider</dt>
                <dd>@GetSetting("provider")</dd>
                <dt>Model</dt>
                <dd>@GetSetting("model")</dd>
                <dt>Queue behavior</dt>
                <dd>@GetSetting("queue.behavior")</dd>
            </dl>
        </section>
        <section class="panel">
            <h2>Memory</h2>
            <dl>
                <dt>Enabled</dt>
                <dd>@GetSetting("memory.enabled")</dd>
                <dt>Scout limit</dt>
                <dd>@GetSetting("memory.scoutLimit")</dd>
                <dt>Extraction</dt>
                <dd>@GetSetting("memory.extraction.mode")</dd>
                <dt>SQLite</dt>
                <dd>@MemoryOptions.Value.ConnectionString</dd>
            </dl>
        </section>
        <section class="panel">
            <h2>Compaction</h2>
            <dl>
                <dt>Threshold</dt>
                <dd>@GetSetting("compaction.threshold")</dd>
                <dt>Recent entries</dt>
                <dd>@GetSetting("compaction.recentEntryCount")</dd>
            </dl>
        </section>
        <section class="panel">
            <h2>Applied Layers</h2>
            <div class="tool-list">
                @foreach (var layer in ResolvedSettings.AppliedLayers)
                {
                    <span>@layer</span>
                }
            </div>
        </section>
    </div>
</section>

@code {
    private AgentSettings ResolvedSettings { get; set; } = new(new Dictionary<string, string>(), []);

    protected override async Task OnInitializedAsync()
    {
        ResolvedSettings = await SettingsResolver.Resolve(
            new AgentSettingsResolveRequest(
                new Conversation("main", ConversationKind.Main, null, null, DateTimeOffset.UtcNow, DateTimeOffset.UtcNow),
                "local-web",
                Directory.GetCurrentDirectory(),
                new Dictionary<string, string>()),
            CancellationToken.None);
    }

    private string GetSetting(string key)
    {
        return ResolvedSettings.Get(key) ?? "unset";
    }
}
