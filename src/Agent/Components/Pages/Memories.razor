@page "/memories"
@rendermode InteractiveServer
@using Agent.Memory
@inject IMemoryDashboardService MemoryService
@inject DashboardUiState UiState

<PageTitle>Memories</PageTitle>

<section class="workspace">
    <header class="workspace-header">
        <div>
            <p class="eyebrow">SQLite memory store</p>
            <h1>Memories</h1>
        </div>
        <div class="toolbar">
            <input @bind="UiState.MemorySearchText" @bind:event="oninput" @onkeyup="LoadMemories" placeholder="Search memories" />
            <select @bind="UiState.LifecycleFilter" @bind:after="LoadMemories">
                @foreach (var lifecycle in Snapshot.Lifecycles)
                {
                    <option value="@lifecycle">@lifecycle</option>
                }
            </select>
            <select @bind="UiState.SegmentFilter" @bind:after="LoadMemories">
                @foreach (var segment in Snapshot.Segments)
                {
                    <option value="@segment">@segment</option>
                }
            </select>
            <select @bind="UiState.TierFilter" @bind:after="LoadMemories">
                @foreach (var tier in Snapshot.Tiers)
                {
                    <option value="@tier">@tier</option>
                }
            </select>
        </div>
    </header>

    <section class="manual-write">
        <textarea @bind="NewMemoryText" placeholder="Manual memory"></textarea>
        <select @bind="NewMemoryTier">
            @foreach (var tier in Enum.GetValues<MemoryTier>())
            {
                <option value="@tier">@tier</option>
            }
        </select>
        <select @bind="NewMemorySegment">
            @foreach (var segment in Enum.GetValues<MemorySegment>())
            {
                <option value="@segment">@segment</option>
            }
        </select>
        <button @onclick="WriteMemory" disabled="@string.IsNullOrWhiteSpace(NewMemoryText)">Write</button>
    </section>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Lifecycle</th>
                    <th>Tier</th>
                    <th>Segment</th>
                    <th>Memory</th>
                    <th>Score</th>
                    <th>Access</th>
                    <th>Source</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Snapshot.Memories.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="empty-cell">No memories match the current filters.</td>
                    </tr>
                }
                else
                {
                    @foreach (var memory in Snapshot.Memories)
                    {
                        <tr class="@(memory.HasDuplicateText ? "has-duplicate" : null)">
                            <td><span class="pill">@memory.Lifecycle</span></td>
                            <td>@memory.Tier</td>
                            <td>@memory.Segment</td>
                            <td>
                                <strong>@memory.Text</strong>
                                @if (memory.HasDuplicateText)
                                {
                                    <small>duplicate text</small>
                                }
                            </td>
                            <td>@memory.Importance.ToString("0.##") / @memory.Confidence.ToString("0.##")</td>
                            <td>@memory.AccessCount / @(memory.LastAccessedAt?.ToLocalTime().ToString("HH:mm") ?? "never")</td>
                            <td class="mono">@((memory.SourceMessageId ?? string.Empty))</td>
                            <td>
                                <div class="button-row">
                                    <button @onclick="() => UpdateLifecycle(memory.Id, MemoryLifecycle.Archived)" disabled="@(memory.Lifecycle == MemoryLifecycle.Archived.ToString())">Archive</button>
                                    <button @onclick="() => UpdateLifecycle(memory.Id, MemoryLifecycle.Active)" disabled="@(memory.Lifecycle == MemoryLifecycle.Active.ToString())">Restore</button>
                                    <button class="danger" @onclick="() => DeleteMemory(memory.Id)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

@code {
    private MemoryWorkspaceSnapshot Snapshot { get; set; } = new([], ["All", "Active", "Archived", "Pruned"], ["All"], ["All"]);

    private string NewMemoryText { get; set; } = string.Empty;

    private MemoryTier NewMemoryTier { get; set; } = MemoryTier.Long;

    private MemorySegment NewMemorySegment { get; set; } = MemorySegment.Context;

    protected override async Task OnInitializedAsync()
    {
        await LoadMemories();
    }

    private async Task LoadMemories()
    {
        Snapshot = await MemoryService.Search(
            new MemorySearchFilter(
                UiState.MemorySearchText,
                UiState.LifecycleFilter,
                UiState.SegmentFilter,
                UiState.TierFilter),
            CancellationToken.None);
    }

    private async Task WriteMemory()
    {
        if (string.IsNullOrWhiteSpace(NewMemoryText))
        {
            return;
        }

        await MemoryService.Write(
            new MemoryWriteDto(NewMemoryText, NewMemoryTier, NewMemorySegment, 0.7, 0.9),
            CancellationToken.None);
        NewMemoryText = string.Empty;
        await LoadMemories();
    }

    private async Task UpdateLifecycle(string id, MemoryLifecycle lifecycle)
    {
        await MemoryService.UpdateLifecycle(id, new MemoryLifecycleUpdateDto(lifecycle), CancellationToken.None);
        await LoadMemories();
    }

    private async Task DeleteMemory(string id)
    {
        await MemoryService.Delete(id, CancellationToken.None);
        await LoadMemories();
    }
}
