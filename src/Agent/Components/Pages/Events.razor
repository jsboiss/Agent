@page "/events"
@page "/runs"
@rendermode InteractiveServer
@inject IRunTimelineService RunService
@inject DashboardUiState UiState

<PageTitle>Runs</PageTitle>

<section class="workspace runs-layout">
    <div>
        <header class="workspace-header">
            <div>
                <p class="eyebrow">Turn timeline</p>
                <h1>Runs</h1>
            </div>
            <div class="toolbar">
                <input @bind="ConversationFilter" placeholder="Conversation id" />
                <select @bind="TimelineFilter">
                    <option>All</option>
                    <option>Provider</option>
                    <option>Tool</option>
                    <option>Memory</option>
                    <option>Error</option>
                </select>
                <button @onclick="LoadRuns">Refresh</button>
            </div>
        </header>

        <div class="timeline">
            @if (Snapshot.Events.Count == 0)
            {
                <div class="empty-state">
                    <h2>No run events</h2>
                    <p>Events appear here after a message is processed.</p>
                </div>
            }
            else
            {
                @foreach (var turn in Snapshot.Turns)
                {
                    <section class="turn-group">
                        <button class="turn-header" @onclick="() => ToggleTurn(turn.Title)">
                            <span class="turn-caret">@(IsTurnCollapsed(turn.Title) ? "+" : "-")</span>
                            <strong>@turn.Title</strong>
                            <span>@turn.StartedAt.ToLocalTime().ToString("g")</span>
                            <small>@turn.Events.Count events</small>
                        </button>
                        @if (!IsTurnCollapsed(turn.Title))
                        {
                            @foreach (var item in turn.Events)
                            {
                                <button class="timeline-event @(item.IsError ? "is-error" : null)" @onclick="() => SelectEvent(item.Id)">
                                    <span>@item.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <strong>@item.Phase</strong>
                                    <em>@item.Kind</em>
                                    <small>@item.Summary</small>
                                </button>
                            }
                        }
                    </section>
                }
            }
        </div>
    </div>

    <aside class="panel inspector sticky">
        <div class="panel-heading">
            <h2>Event Detail</h2>
        </div>
        @if (SelectedEvent is null)
        {
            <p class="muted">Select an event to inspect its raw metadata.</p>
        }
        else
        {
            <h3>@SelectedEvent.Kind</h3>
            <p>@SelectedEvent.Summary</p>
            <dl>
                <dt>Conversation</dt>
                <dd>@SelectedEvent.ConversationId</dd>
                <dt>Phase</dt>
                <dd>@SelectedEvent.Phase</dd>
                @foreach (var item in SelectedEvent.Metadata)
                {
                    <dt>@item.Key</dt>
                    <dd>@item.Value</dd>
                }
            </dl>
        }
    </aside>
</section>

@code {
    private RunTimelineSnapshot Snapshot { get; set; } = new("main", [], []);

    private string ConversationFilter { get; set; } = "main";

    private string TimelineFilter { get; set; } = "All";

    private HashSet<string> CollapsedTurnTitles { get; } = [];

    private RunEventRow? SelectedEvent => Snapshot.Events.FirstOrDefault(x => x.Id == UiState.SelectedRunEventId);

    protected override async Task OnInitializedAsync()
    {
        ConversationFilter = UiState.ConversationId;
        await LoadRuns();
    }

    private async Task LoadRuns()
    {
        Snapshot = await RunService.List(ConversationFilter, TimelineFilter, CancellationToken.None);
    }

    private void SelectEvent(string id)
    {
        UiState.SelectedRunEventId = id;
    }

    private bool IsTurnCollapsed(string title)
    {
        return CollapsedTurnTitles.Contains(title);
    }

    private void ToggleTurn(string title)
    {
        if (!CollapsedTurnTitles.Add(title))
        {
            CollapsedTurnTitles.Remove(title);
        }
    }
}
