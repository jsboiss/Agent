@page "/"
@rendermode InteractiveServer
@using System.Net
@inject IChatDashboardService ChatService
@inject DashboardUiState UiState
@inject IJSRuntime JsRuntime

<PageTitle>Chat</PageTitle>

<section class="workspace chat-workspace">
    <div class="pane pane-chat chat-only">
        <header class="workspace-header">
            <div>
                <p class="eyebrow">Main conversation</p>
                <h1>Chat Cockpit</h1>
            </div>
            <div class="status-strip">
                <span>@Snapshot.Provider</span>
                <strong>@Snapshot.Model</strong>
            </div>
        </header>

        <div class="transcript" id="chat-transcript">
            @if (VisibleMessages.Count == 0)
            {
                <div class="empty-state">
                    <h2>No messages yet</h2>
                    <p>Start the main local-web conversation. Memory injection and tool activity will appear beside the transcript.</p>
                </div>
            }
            else
            {
                @foreach (var message in VisibleMessages)
                {
                    <article class="message @GetMessageClass(message.Role)">
                        <header>
                            <span>@message.Role</span>
                            <time>@message.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</time>
                        </header>
                        <div class="markdown-body" @key="message.Id">@((MarkupString)message.HtmlContent)</div>
                    </article>
                }

                @if (IsSending)
                {
                    <article class="message from-agent typing-message" aria-live="polite">
                        <header>
                            <span>Assistant</span>
                            <time></time>
                        </header>
                        <div class="typing-indicator" aria-label="Waiting for assistant response">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </article>
                }
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="callout error">@ErrorMessage</div>
        }

        <form class="composer" @onsubmit="SendMessage" @onsubmit:preventDefault="true">
            <textarea id="chat-composer"
                      @bind="Prompt"
                      @bind:event="oninput"
                      disabled="@IsSending"
                      placeholder="Message the agent"></textarea>
            <button id="chat-send-button" type="submit" disabled="@(!CanSend)">
                @(IsSending ? "Sending" : "Send")
            </button>
        </form>
    </div>
</section>

@code {
    private ChatDashboardSnapshot Snapshot { get; set; } = EmptySnapshot;

    private string Prompt { get; set; } = string.Empty;

    private string? ErrorMessage { get; set; }

    private bool IsSending { get; set; }

    private List<ChatDashboardMessage> PendingMessages { get; } = [];

    private IReadOnlyList<ChatDashboardMessage> VisibleMessages => Snapshot.Messages
        .Concat(PendingMessages)
        .OrderBy(x => x.CreatedAt)
        .ToArray();

    private bool CanSend => !IsSending && !string.IsNullOrWhiteSpace(Prompt);

    private static ChatDashboardSnapshot EmptySnapshot { get; } = new(
        "main",
        [],
        [],
        [],
        [],
        "Ollama",
        "qwen3.5:latest",
        false,
        null);

    protected override async Task OnInitializedAsync()
    {
        Snapshot = await ChatService.LoadMain(CancellationToken.None);
        UiState.ConversationId = Snapshot.ConversationId;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JsRuntime.InvokeVoidAsync("agentDashboard.attachComposer", "chat-composer", "chat-send-button");
        }

        await JsRuntime.InvokeVoidAsync("agentDashboard.highlight");
    }

    private async Task SendMessage()
    {
        if (!CanSend)
        {
            return;
        }

        var prompt = Prompt;
        Prompt = string.Empty;
        ErrorMessage = null;
        IsSending = true;
        PendingMessages.Add(new ChatDashboardMessage(
            $"pending:{Guid.NewGuid():N}",
            "You",
            prompt,
            $"<p>{WebUtility.HtmlEncode(prompt).Replace("\r\n", "<br>").Replace("\n", "<br>")}</p>",
            DateTimeOffset.UtcNow));
        await InvokeAsync(StateHasChanged);

        try
        {
            var response = await ChatService.SendPrompt(new SendChatMessageRequest(prompt), CancellationToken.None);
            Snapshot = response.Snapshot;
            UiState.ConversationId = Snapshot.ConversationId;
            ErrorMessage = response.ErrorMessage;
            PendingMessages.Clear();
        }
        finally
        {
            IsSending = false;
        }
    }

    private static string GetMessageClass(string role)
    {
        return role == "You" ? "from-user" : "from-agent";
    }
}
