@page "/graph"
@rendermode InteractiveServer
@inject IMemoryGraphService GraphService
@inject IJSRuntime JsRuntime

<PageTitle>Graph</PageTitle>

<section class="workspace">
    <header class="workspace-header">
        <div>
            <p class="eyebrow">Memory topology</p>
            <h1>Graph</h1>
        </div>
        <button @onclick="RenderGraph">Refresh</button>
    </header>

    @if (Snapshot.Nodes.Count == 0)
    {
        <div class="empty-state graph-empty">
            <h2>No graph data</h2>
            <p>@Snapshot.EmptyReason</p>
        </div>
    }
    else
    {
        <div id="memory-graph" class="graph-canvas"></div>
    }
</section>

@code {
    private MemoryGraphSnapshot Snapshot { get; set; } = new([], [], "Loading graph data.");

    protected override async Task OnInitializedAsync()
    {
        Snapshot = await GraphService.Build(CancellationToken.None);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Snapshot.Nodes.Count > 0)
        {
            await RenderGraph();
        }
    }

    private async Task RenderGraph()
    {
        Snapshot = await GraphService.Build(CancellationToken.None);

        if (Snapshot.Nodes.Count > 0)
        {
            await JsRuntime.InvokeVoidAsync("agentDashboard.renderMemoryGraphFromEndpoint", "memory-graph", "/api/dashboard/graph");
        }
    }
}
