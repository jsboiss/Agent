    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@tanstack/react-query": "^5.90.7",
    "ai": "^6.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.3.0",
    "orval": "^7.13.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1"
  }
